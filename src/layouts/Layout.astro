---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale: string;
  alternateLocales: { locale: string; url: string }[];
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description,
  locale,
  alternateLocales,
  canonicalUrl,
  ogImage = '/images/timestamp_header.jpg',
} = Astro.props;

const siteUrl = 'https://timestamp.camera';
const resolvedCanonical = canonicalUrl || Astro.url.href;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang={locale} class="">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Hreflang -->
    {alternateLocales.map(({ locale: loc, url }) => (
      <link rel="alternate" hreflang={loc} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:locale" content={locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- App Deep Links -->
    <meta property="al:ios:url" content="timestamp://" />
    <meta property="al:ios:app_store_id" content="1115974495" />
    <meta property="al:ios:app_name" content="Timestamp" />
    <meta property="al:android:url" content="timestamp://" />
    <meta property="al:android:package" content="com.artifyapp.timestamp" />
    <meta property="al:android:app_name" content="Timestamp" />

    <!-- Smart App Banner -->
    <meta name="apple-itunes-app" content="app-id=1115974495" />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-icon-180x180.png" />
    <link rel="manifest" href="/favicon/manifest.json" />

    <!-- GA4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-WZWPM4MKZ4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-WZWPM4MKZ4');
    </script>

    <!-- Dark mode script (runs before paint to prevent flash) -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>
