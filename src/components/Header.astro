---
import { locales, getToolSlug, type TranslationData } from '../i18n/index';

interface Props {
  locale: string;
  t: TranslationData;
}

const { locale, t } = Astro.props;
const toolSlug = getToolSlug(locale);
const currentLocaleName = locales.find((l) => l.code === locale)?.name ?? 'English';
const base = `/${locale}/`;
---

<header
  class="sticky top-0 z-50 w-full border-b border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-gray-950/80 backdrop-blur-md"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href={`/${locale}/`} class="flex items-center gap-2 shrink-0">
        <img src="/images/logo.png" alt="Timestamp" class="h-8 w-8 rounded-lg" width="32" height="32" />
        <span class="text-lg font-bold text-gray-900 dark:text-white">Timestamp</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6">
        <a href={`${base}#features`} class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          {t.nav.features}
        </a>
        <a href={`${base}#faq`} class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          {t.nav.faq}
        </a>
        <a href={`${base}#download`} class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          {t.nav.download}
        </a>
        <a
          href={`/${locale}/${toolSlug}/`}
          class="text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors"
        >
          {t.nav.tool}
        </a>
      </nav>

      <!-- Right side controls -->
      <div class="flex items-center gap-2">
        <!-- Language selector -->
        <div class="relative" data-lang-dropdown>
          <button
            type="button"
            class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            data-lang-toggle
            aria-label="Select language"
            aria-expanded="false"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z" />
            </svg>
            <span class="hidden sm:inline">{currentLocaleName}</span>
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>
          <div
            class="absolute right-0 mt-1 hidden w-44 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 shadow-lg py-1 z-50"
            data-lang-menu
          >
            {locales.map((loc) => (
              <a
                href={`/${loc.code}/`}
                class:list={[
                  'block px-4 py-2 text-sm transition-colors',
                  loc.code === locale
                    ? 'text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-950 font-medium'
                    : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800',
                ]}
              >
                {loc.name}
              </a>
            ))}
          </div>
        </div>

        <!-- Dark mode toggle -->
        <button
          type="button"
          class="rounded-lg p-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          data-theme-toggle
          aria-label="Toggle dark mode"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5" />
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>

        <!-- Mobile hamburger -->
        <button
          type="button"
          class="md:hidden rounded-lg p-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          data-mobile-toggle
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav
      class="hidden md:hidden border-t border-gray-200 dark:border-gray-800 py-4 space-y-2"
      data-mobile-menu
    >
      <a href={`${base}#features`} class="block rounded-lg px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        {t.nav.features}
      </a>
      <a href={`${base}#faq`} class="block rounded-lg px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        {t.nav.faq}
      </a>
      <a href={`${base}#download`} class="block rounded-lg px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        {t.nav.download}
      </a>
      <a
        href={`/${locale}/${toolSlug}/`}
        class="block rounded-lg px-3 py-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        {t.nav.tool}
      </a>
    </nav>
  </div>
</header>

<script>
  // Language dropdown toggle
  document.querySelectorAll('[data-lang-dropdown]').forEach((dropdown) => {
    const toggle = dropdown.querySelector('[data-lang-toggle]');
    const menu = dropdown.querySelector('[data-lang-menu]');
    if (!toggle || !menu) return;

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!menu.classList.contains('hidden')));
    });

    document.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });

  // Dark mode toggle
  document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      if (isDark) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  });

  // Mobile menu toggle
  document.querySelectorAll('[data-mobile-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const menu = document.querySelector('[data-mobile-menu]');
      if (menu) {
        menu.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!menu.classList.contains('hidden')));
      }
    });
  });

  // Close mobile menu on link click
  document.querySelectorAll('[data-mobile-menu] a').forEach((link) => {
    link.addEventListener('click', () => {
      const menu = document.querySelector('[data-mobile-menu]');
      if (menu) {
        menu.classList.add('hidden');
      }
    });
  });
</script>
