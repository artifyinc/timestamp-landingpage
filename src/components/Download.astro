---
import type { TranslationData } from '../i18n/index';

interface Props {
  t: TranslationData;
}

const { t } = Astro.props;
---

<section id="download" class="py-20 sm:py-24 bg-gradient-to-b from-primary-50 to-white dark:from-gray-900 dark:to-gray-950">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">
      {t.download.title}
    </h2>
    <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
      {t.download.subtitle}
    </p>

    <!-- Store buttons -->
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <!-- App Store -->
      <a
        href="https://itunes.apple.com/app/id1115974495"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-xl bg-gray-900 dark:bg-white px-6 py-3.5 text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors shadow-lg"
      >
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <div class="text-left">
          <div class="text-xs opacity-80">Download on the</div>
          <div class="text-lg font-semibold leading-tight">{t.download.appStore}</div>
        </div>
      </a>

      <!-- Play Store -->
      <a
        href="https://play.google.com/store/apps/details?id=com.artifyapp.timestamp"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-xl bg-gray-900 dark:bg-white px-6 py-3.5 text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors shadow-lg"
      >
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.834 1.639a1 1 0 010 1.74l-2.834 1.639-2.532-2.532 2.532-2.486zM5.864 3.458L16.8 9.791l-2.302 2.302-8.634-8.635z"/>
        </svg>
        <div class="text-left">
          <div class="text-xs opacity-80">Get it on</div>
          <div class="text-lg font-semibold leading-tight">{t.download.playStore}</div>
        </div>
      </a>
    </div>

    <!-- Rating -->
    <div class="mt-8 flex items-center justify-center gap-2">
      <div class="flex text-yellow-400">
        {[...Array(5)].map(() => (
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <span class="text-sm font-medium text-gray-600 dark:text-gray-400">
        4.8 &middot; 140K+ reviews
      </span>
    </div>
  </div>
</section>
