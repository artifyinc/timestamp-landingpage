---
import { getToolSlug, type TranslationData } from '../i18n/index';

interface Props {
  locale: string;
  t: TranslationData;
}

const { locale, t } = Astro.props;
const toolSlug = getToolSlug(locale);
---

<section class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white dark:from-gray-900 dark:to-gray-950">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text content -->
      <div class="text-center lg:text-left">
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-white whitespace-pre-line leading-tight"
        >
          {t.hero.title}
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-xl mx-auto lg:mx-0">
          {t.hero.subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="#download"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-primary-600/25 hover:bg-primary-700 transition-colors"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            {t.hero.cta}
          </a>
          <a
            href={`/${locale}/${toolSlug}/`}
            class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-gray-300 dark:border-gray-600 px-6 py-3.5 text-base font-semibold text-gray-700 dark:text-gray-200 hover:border-primary-500 hover:text-primary-600 dark:hover:border-primary-400 dark:hover:text-primary-400 transition-colors"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5" />
            </svg>
            {t.hero.webTool}
          </a>
        </div>

        <!-- Rating badge -->
        <div class="mt-8 flex items-center justify-center lg:justify-start gap-2">
          <div class="flex text-yellow-400">
            {[...Array(5)].map((_, i) => (
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-400">
            4.8 &middot; 140K+ reviews
          </span>
        </div>
      </div>

      <!-- App mockup -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-tr from-primary-400/20 to-primary-600/20 rounded-[3rem] blur-2xl"></div>
          <div class="iphone-frame relative w-64 sm:w-72 lg:w-80">
            <div class="iphone-screen">
              <img
                src="/images/iPhone_Home.jpg"
                alt="Timestamp Camera App"
                width="640"
                height="1391"
                loading="eager"
              />
            </div>
            <div class="iphone-side-button iphone-side-button--power"></div>
            <div class="iphone-side-button iphone-side-button--vol-up"></div>
            <div class="iphone-side-button iphone-side-button--vol-down"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .iphone-frame {
    background: linear-gradient(135deg, #2a2a2c, #1d1d1f, #2a2a2c);
    border-radius: 3rem;
    padding: 0.65rem;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 0 0 1px rgba(0, 0, 0, 0.3),
      0 20px 50px rgba(0, 0, 0, 0.25),
      0 4px 12px rgba(0, 0, 0, 0.15);
  }

  .iphone-screen {
    border-radius: 2.4rem;
    overflow: hidden;
    background: #000;
  }

  .iphone-screen img {
    width: 100%;
    height: auto;
    display: block;
  }

  .iphone-side-button {
    position: absolute;
    background: linear-gradient(180deg, #3a3a3c, #2a2a2c);
    border-radius: 2px;
  }

  .iphone-side-button--power {
    right: -2px;
    top: 22%;
    width: 2px;
    height: 12%;
  }

  .iphone-side-button--vol-up {
    left: -2px;
    top: 18%;
    width: 2px;
    height: 7%;
  }

  .iphone-side-button--vol-down {
    left: -2px;
    top: 27%;
    width: 2px;
    height: 7%;
  }
</style>
